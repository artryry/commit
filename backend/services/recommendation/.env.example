GRPC_HOST=0.0.0.0
GRPC_PORT=50052

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=my_own_password_123
DB_NAME=recommendations

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_STACK_TTL_SECONDS=86400

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=recommendation-service
KAFKA_TOPIC_PROFILE_UPDATED=profile.updated
KAFKA_TOPIC_USER_DELETED=user.deleted

RECOMMENDATIONS_BATCH_SIZE=25

# Compatibility: single Ollama model. Pull: docker exec -it ollama ollama pull qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SEC=180
# Per peer id, one Ollama call; token cap for 7–10 Russian sentences
COMPATIBILITY_NUM_PREDICT=4096

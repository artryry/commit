# Application settings
APP_NAME=Authentication Service
APP_VERSION=1.0.0

# Browser Origin values for CORS (not hostnames of other containers). Include Swagger UI (:8088) and gateway (:18000).
ORIGINS=["http://localhost:8088","http://127.0.0.1:8088","http://localhost:18000","http://127.0.0.1:18000","http://localhost:18001","http://127.0.0.1:18001"]

# Kafka settings
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_USER_CREATED_TOPIC=user.created
KAFKA_USER_DELETED_TOPIC=user.deleted

# Database settings
DB_HOST=db-auth
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=my_own_password_123
DB_NAME=auth_users

# JWT settings
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password settings
MIN_PASSWORD_LENGTH=8

# Debug settings
DEBUG=true
